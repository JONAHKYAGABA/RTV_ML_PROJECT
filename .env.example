# =============================================================================
# RTV Multi-Agent ML System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Optional: OpenAI for embeddings fallback
OPENAI_API_KEY=your-openai-api-key-here

# --- Model Configuration ---
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
JUDGE_MODEL=claude-sonnet-4-20250514

# --- Database ---
DUCKDB_PATH=data/rtv_households.duckdb

# --- Vector Store (Qdrant) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rtv_handbook
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Redis (Caching & Conversation Memory) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Object Storage (MinIO / S3-compatible) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rtv-artifacts

# --- Tracing (OpenTelemetry / Jaeger) ---
OTEL_ENDPOINT=http://localhost:4317

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
LOG_LEVEL=INFO

# --- RAG Configuration ---
CHUNK_SIZE=900
CHUNK_OVERLAP=180
TOP_K=5
RERANK_TOP_K=3
