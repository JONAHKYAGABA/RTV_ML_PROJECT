# =============================================================================
# RTV Multi-Agent ML System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Model Configuration ---
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
JUDGE_MODEL=claude-sonnet-4-20250514

# --- Database ---
DUCKDB_PATH=data/rtv_households.duckdb

# --- Vector Store (Qdrant) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=rtv_handbook
EMBEDDING_MODEL=BAAI/bge-m3

# --- Redis (Caching & Conversation Memory) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Object Storage (MinIO / S3) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rtv-artifacts

# --- Tracing (OpenTelemetry / Jaeger) ---
OTEL_ENDPOINT=http://jaeger:4317

# --- Observability: LangSmith ---
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=rtv-multi-agent-system

# --- Experiment Tracking: Weights & Biases ---
WANDB_API_KEY=your-wandb-api-key-here
WANDB_PROJECT=rtv-multi-agent-eval

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
LOG_LEVEL=INFO

# --- RAG Configuration ---
CHUNK_SIZE=900
CHUNK_OVERLAP=180
TOP_K=5
RERANK_TOP_K=3
